{
  // ─────────────────────────────────────────────────────────────
  // 빌드 전용 tsconfig.
  // tsconfig.json을 상속받되, 배포 패키지에 들어가면 안 되는 것들(테스트, spec 등)을 추가로 제외합니다.
  // npm publish 시에는 이 파일로 빌드된 dist/ 폴더만 사용자에게 전달됩니다.
  // ─────────────────────────────────────────────────────────────
  "extends": "./tsconfig.json",
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
