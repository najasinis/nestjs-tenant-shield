# ─────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/
jspm_packages/

# ─────────────────────────────────────────────────────────────
# Build output (tsup → CJS + ESM + .d.ts)
# ─────────────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────
# Test / Coverage (Jest)
# ─────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
junit.xml

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────────────────────
# Environment variables (보안 민감 — 절대 커밋 금지)
# audit-log는 GENESIS_HASH 같은 환경별 시크릿을 사용
# ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
.env.test

# ─────────────────────────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─────────────────────────────────────────────────────────────
# OS metadata
# ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────
# NestJS / TypeScript
# ─────────────────────────────────────────────────────────────
.tsbuildinfo

# ─────────────────────────────────────────────────────────────
# Package manager artifacts
# pnpm-lock.yaml은 라이브러리이므로 커밋함 (재현 가능한 빌드용)
# ─────────────────────────────────────────────────────────────
.pnpm-store/
package-lock.json
yarn.lock

# ─────────────────────────────────────────────────────────────
# npm 배포 산출물
# ─────────────────────────────────────────────────────────────
*.tgz
.npm/

# ─────────────────────────────────────────────────────────────
# Examples — 데모 앱의 빌드/의존성 산출물
# (소스는 커밋, 빌드 결과는 제외)
# ─────────────────────────────────────────────────────────────
examples/*/node_modules/
examples/*/dist/
examples/*/.env

# ─────────────────────────────────────────────────────────────
# 임시 / 캐시
# ─────────────────────────────────────────────────────────────
.cache/
.temp/
.tmp/
tmp/
temp/

# ─────────────────────────────────────────────────────────────
# Claude Code / AI tooling 로컬 설정 (개인 환경)
# claude/ 폴더의 하네스 문서는 커밋 (CLAUDE.md, ARCHITECTURE.md 등)
# 단, 로컬 권한/세션은 제외
# ─────────────────────────────────────────────────────────────
.claude/settings.local.json
.claude/sessions/
.claude/cache/
