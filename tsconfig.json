{
  // ─────────────────────────────────────────────────────────────
  // TypeScript 컴파일러 설정 (개발용)
  // 이 파일은 IDE(VSCode 등)와 ts-jest, ts-node 같은 도구들이 참고합니다.
  // 실제 npm 배포용 빌드는 tsconfig.build.json을 사용합니다.
  // ─────────────────────────────────────────────────────────────
  "compilerOptions": {
    // 컴파일 결과물의 JavaScript 버전. Node 18+에서 ES2021 기능을 안정적으로 지원.
    "target": "ES2021",

    // 모듈 시스템. NestJS는 CommonJS를 기본으로 사용 (require/module.exports 형태).
    "module": "commonjs",

    // 컴파일된 .js 파일이 출력될 폴더.
    "outDir": "./dist",

    // 소스 파일들이 있는 루트 폴더.
    "rootDir": "./src",

    // 데코레이터를 사용하려면 필수. NestJS의 @Injectable, @Module 등이 모두 데코레이터.
    "experimentalDecorators": true,

    // @Injectable() 클래스의 생성자 파라미터 타입 메타데이터를 자동으로 emit. DI에 필수.
    "emitDecoratorMetadata": true,

    // 라이브러리 사용자에게 타입 정보(.d.ts)를 제공해 자동 완성과 타입 체크가 동작하게 함.
    "declaration": true,

    // .d.ts 파일에 소스맵 첨부. 사용자가 "Go to Definition"하면 원본 .ts로 점프.
    "declarationMap": true,

    // 디버깅용 .map 파일. 컴파일된 .js에서 .ts 원본으로 매핑.
    "sourceMap": true,

    // 엄격 모드. 모든 strict 옵션을 한 번에 켭니다. 라이브러리는 반드시 켜야 안전.
    "strict": true,

    // 사용하지 않는 지역 변수는 에러로 표시. 깔끔한 코드 유지.
    "noUnusedLocals": true,

    // 사용하지 않는 함수 파라미터도 에러. (단, '_'로 시작하는 파라미터는 허용됨)
    "noUnusedParameters": true,

    // switch case에서 break를 빠뜨리는 실수를 방지.
    "noFallthroughCasesInSwitch": true,

    // CommonJS 모듈을 ES Module처럼 default import 할 수 있게 해줍니다.
    "esModuleInterop": true,

    // import 경로의 대소문자 일관성을 강제 (macOS는 안 잡지만 Linux 빌드 깨짐 방지).
    "forceConsistentCasingInFileNames": true,

    // JSON 파일을 ts에서 import 가능하게 (package.json에서 버전 읽을 때 등).
    "resolveJsonModule": true,

    // node_modules의 라이브러리들 타입 체크를 스킵. 빌드 속도 향상 + 외부 타입 오류로부터 격리.
    "skipLibCheck": true
  },

  // 컴파일 대상 파일 패턴.
  "include": ["src/**/*"],

  // 컴파일에서 제외할 경로. 의존성, 빌드 결과, 테스트는 제외.
  "exclude": ["node_modules", "dist", "test", "**/*.spec.ts"]
}
